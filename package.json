{
  "name": "alzhal",
  "version": "1.0.0",
  "description": "Alzhal — regulation-grounded ingredient safety analyzer. Send a product photo, ingredient list, or voice note via web, WhatsApp, or Telegram; get a plain-language safety verdict backed by FDA, EU, WHO/IARC, FSSAI and other official sources.",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "cf:build": "npx opennextjs-cloudflare build",
    "preview": "npm run cf:build && npx wrangler dev",
    "deploy": "npm run cf:build && npx wrangler deploy",
    "seed:iarc": "npx tsx scripts/seed-iarc-cig.ts",
    "eval": "npx tsx scripts/eval-harness.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ingredient-safety",
    "food-safety",
    "regulatory",
    "fda",
    "fssai",
    "iarc",
    "cloudflare-workers",
    "nextjs",
    "gemini",
    "whatsapp-bot",
    "telegram-bot"
  ],
  "author": "Alzhal contributors",
  "license": "Apache-2.0",
  "private": true,
  "homepage": "https://github.com/quantumsequrity/alzhal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quantumsequrity/alzhal.git"
  },
  "bugs": {
    "url": "https://github.com/quantumsequrity/alzhal/issues"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "busboy": "^1.6.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "formidable": "^3.5.4",
    "google-tts-api": "^2.0.2",
    "lucide-react": "^1.14.0",
    "next": "^16.1.6",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.1.18",
    "tesseract.js": "^7.0.0",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@opennextjs/cloudflare": "^1.16.5",
    "wrangler": "^4.65.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
