# Google Gemini API
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Temperature (0.0 = deterministic, 1.0 = creative)
# Recommended: 0.2 for balanced consistency + quality
# Lower values (0.1-0.3) provide more consistent safety verdicts
# Higher values (0.5-0.8) allow more variation in explanations
GEMINI_TEMPERATURE=0.2

# Meta WhatsApp Business API
# Get from: https://developers.facebook.com/apps/
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_APP_SECRET=your_app_secret

# Telegram Bot API
# Create a bot via @BotFather on Telegram, then paste the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Webhook secret. Required in production. Telegram echoes this back on every
# webhook call via the X-Telegram-Bot-Api-Secret-Token header. Without it,
# anyone who knows the webhook URL can forge updates pretending to be any user.
# Generate with: `openssl rand -hex 32`
# Allowed chars: A-Z, a-z, 0-9, _, - (length 1-256)
TELEGRAM_WEBHOOK_SECRET=your_random_webhook_secret

# Secret used to gate /api/telegram/setup. This is separate from the bot
# token so the bot token never appears in URLs / server access logs.
# Generate with: `openssl rand -hex 32`
TELEGRAM_SETUP_SECRET=your_random_setup_secret

# Optional: App URL for Webhooks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- v2-grounded feature flag ---
# Set to "true" to route ingredient analysis through the grounded pipeline
# (regulatory_fact lookup + renderGroundedFacts). Requires the REGULATORY_DB
# D1 binding in wrangler.toml and schema applied. Falls back to legacy
# pipeline when false, binding missing, or ingredient not indexed.
USE_GROUNDED_RENDERER=false

# --- Renderer backend ---
# Which LLM powers the grounded renderer's prose step (simple_name /
# how_its_made / safety_summary).
#   gemini  (default) → Gemini 2.0 Flash
#   gemma            → Cloudflare Workers AI (Gemma 4 26B-A4B by default),
#                      with automatic fallback to Gemini on any failure.
# OCR and other Gemini calls are unaffected.
RENDERER_BACKEND=gemini

# Override the Workers AI model ID when RENDERER_BACKEND=gemma.
# Defaults to @cf/google/gemma-4-26b-a4b-it.
# Alternatives in the Workers AI catalog: @cf/google/gemma-3-12b-it.
# RENDERER_MODEL=@cf/google/gemma-4-26b-a4b-it
